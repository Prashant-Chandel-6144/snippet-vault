{
  "expo": {
    "name": "DevVault",
    "slug": "dev-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "devvault",
    "userInterfaceStyle": "automatic",
    
    "android": {
      "package": "com.prashant2011.devvault",
      "adaptiveIcon": {
        "backgroundColor": "#0B1220",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1220",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain"
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain"
          }
        }
      ],
      "expo-image",
      "expo-sqlite",
      "expo-secure-store",
      "expo-sharing",
      "expo-asset",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4074060c-aca0-4fd8-a205-daac41c531f0"
      }
    },
    "owner": "prashant2011",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4074060c-aca0-4fd8-a205-daac41c531f0"
    }
  }
}
